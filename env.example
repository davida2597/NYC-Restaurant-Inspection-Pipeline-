# =============================================================================
# .env.example — Local development environment template
# =============================================================================
#
# INSTRUCTIONS FOR DEVELOPERS
# ----------------------------
# 1. Copy this file and rename the copy to ".env"  (do NOT rename this file)
#         cp .env.example .env
#
# 2. Fill in your own values in .env (see notes below each variable)
#
# 3. NEVER commit your .env file to GitHub. It is already listed in .gitignore.
#    This .env.example file is safe to commit — it contains no real secrets.
#
# 4. The production values (real keys, real passwords) are stored as GitHub
#    Actions Secrets and are never written in any file in this repo.
#
# =============================================================================


# -----------------------------------------------------------------------------
# NYC OPEN DATA — DIRECT REST API
# Dataset: DOHMH Restaurant Inspection Results
# Base URL: https://data.cityofnewyork.us/resource/43nn-pn8j.json
# Docs:     https://dev.socrata.com/foundry/data.cityofnewyork.us/43nn-pn8j
#
# Requests are plain HTTP GET calls with $limit and $offset query parameters.
# No SDK required — just the requests library.
#
# Example:
#   GET https://data.cityofnewyork.us/resource/43nn-pn8j.json
#       ?$limit=1000
#       &$offset=0
#       &$order=inspection_date ASC
#       &$$app_token=your_app_token_here
# -----------------------------------------------------------------------------

# Full base URL for the dataset endpoint. Do not change this.
API_BASE_URL=https://data.cityofnewyork.us/resource/43nn-pn8j.json

# Your NYC Open Data app token.
# Requests without a token still work but share a throttled anonymous
# rate limit — you will hit errors quickly when fetching in large batches.
# Register for a free token in ~30 seconds at:
#   https://data.cityofnewyork.us/profile/app_tokens
# Each developer should register their own token.
API_APP_TOKEN=your_app_token_here


# -----------------------------------------------------------------------------
# SUPABASE — API KEYS (new sb_ format, replaces legacy anon/service_role)
#
# Where to find these:
#   Supabase Dashboard -> Project Settings -> API Keys -> API Keys tab
#   (NOT the Legacy API Keys tab)
#
# New projects only have the sb_ keys. If you see long JWT strings (eyJ...)
# in your dashboard, those are the old legacy keys — use the API Keys tab
# to generate the new ones instead.
# -----------------------------------------------------------------------------

# Your Supabase project URL. Does not change.
# Looks like: https://xxxxxxxxxxxx.supabase.co
SUPABASE_URL=https://your-project-ref.supabase.co

# Publishable key (sb_publishable_...) — replaces the old anon key.
# Safe to use in any script that only reads data or uploads to Storage.
# Use this for: fetch_new.py, fetch_all.py, clean_data.py, streamlit_app.py
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# Secret key (sb_secret_...) — replaces the old service_role key.
# Has full database access and bypasses Row Level Security.
# Treat this exactly like a password — do not share over Slack or email.
# Use this for: port_data.py, setup_db.py (anything that writes to the DB)
# You only need this if you are running those two scripts locally.
SUPABASE_SECRET_KEY=sb_secret_your_key_here

# Convenience alias used by most scripts. Set to your publishable key for
# read/storage work, or your secret key if running port_data.py/setup_db.py.
SUPABASE_KEY=sb_publishable_your_key_here


# -----------------------------------------------------------------------------
# SUPABASE — DATABASE CONNECTION (Supavisor session pooler)
# Needed ONLY by: setup_db.py, port_data.py
#
# Where to find this:
#   Supabase Dashboard -> click the "Connect" button (top of the page)
#   -> Select "Session mode" -> copy the connection string
#
# Use Session mode (port 5432) — it works on both IPv4 and IPv6 networks.
# Do NOT use the "Direct connection" string — it is IPv6 only and will
# fail on most home/office networks unless you have the IPv4 add-on.
#
# The connection string contains your DB password — treat it carefully.
# Format: postgresql://postgres.[project-ref]:[password]@[host]:5432/postgres
# -----------------------------------------------------------------------------

DATABASE_URL=postgresql://postgres.your-project-ref:your-db-password@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# You can also provide the components individually if preferred:
DB_HOST=aws-0-us-east-1.pooler.supabase.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres.your-project-ref
DB_PASSWORD=your-db-password


# -----------------------------------------------------------------------------
# PIPELINE CONFIGURATION — Runtime settings (not secrets)
# -----------------------------------------------------------------------------

# Number of records to request per API call.
# The NYC Open Data API supports up to 50000 per request, but 1000 keeps
# each request lightweight and makes crash recovery easier.
API_BATCH_SIZE=1000

# How many days of data to include per CSV file when running fetch_all.py.
# Smaller = finer-grained files and easier crash recovery. Recommended: 90.
FETCH_BATCH_DAYS=90

# ISO date string for the earliest record to fetch in fetch_all.py.
# The restaurant inspection dataset goes back to around 2010.
FETCH_ALL_START_DATE=2010-01-01

# The column name in the API response used to filter records by date.
API_DATE_FIELD=inspection_date

# Seconds to wait between paginated API requests to avoid rate limiting.
# Increase this if you see 429 (Too Many Requests) errors.
API_REQUEST_DELAY=0.5

# Supabase Storage bucket names. Change only if you named your buckets
# differently when setting them up in the Supabase dashboard.
RAW_BUCKET=raw
CLEANED_BUCKET=cleaned

# Name of the main inspections table created by setup_db.py.
RECORDS_TABLE=inspections


# -----------------------------------------------------------------------------
# NOTES FOR DEVELOPERS
# -----------------------------------------------------------------------------
#
# HOW BATCHED FETCHING WORKS (no SDK):
#   fetch_all.py and fetch_new.py use plain requests.get() calls with
#   $limit and $offset parameters to page through the dataset:
#
#       import requests, os, time
#
#       BASE   = os.environ["API_BASE_URL"]
#       TOKEN  = os.environ["API_APP_TOKEN"]
#       BATCH  = int(os.environ["API_BATCH_SIZE"])   # 1000
#       DELAY  = float(os.environ["API_REQUEST_DELAY"])
#
#       offset = 0
#       while True:
#           resp = requests.get(BASE, params={
#               "$limit":      BATCH,
#               "$offset":     offset,
#               "$order":      "inspection_date ASC",
#               "$$app_token": TOKEN,
#           })
#           resp.raise_for_status()
#           rows = resp.json()
#           if not rows:
#               break
#           # ... process rows ...
#           offset += BATCH
#           time.sleep(DELAY)
#
# WHO NEEDS WHAT:
#
#   Running fetch_new.py or fetch_all.py:
#     -> API_BASE_URL, API_APP_TOKEN
#     -> SUPABASE_URL, SUPABASE_PUBLISHABLE_KEY (to save CSVs to Storage)
#
#   Running clean_data.py:
#     -> SUPABASE_URL, SUPABASE_PUBLISHABLE_KEY
#
#   Running port_data.py or setup_db.py:
#     -> SUPABASE_URL, SUPABASE_SECRET_KEY, DATABASE_URL
#     -> These scripts write to the DB and need the secret key + direct conn.
#
#   Running streamlit_app.py locally:
#     -> SUPABASE_URL, SUPABASE_PUBLISHABLE_KEY
#     -> Streamlit reads from st.secrets in production, but dotenv works
#        locally (see loading instructions below).
#
# DO YOU NEED A SUPABASE ACCOUNT?
#   No. You do not need to be added to the Supabase project to run scripts.
#   You only need the URL and the appropriate key. Ask the project owner to
#   share the relevant key securely (password manager, not Slack or email).
#
# DO YOU NEED TO REGISTER FOR AN APP TOKEN?
#   Technically no — the API works without one. But unauthenticated requests
#   share a global rate limit with all anonymous users. Get a free token at:
#   https://data.cityofnewyork.us/profile/app_tokens
#
# LOADING .env IN PYTHON:
#   Install python-dotenv:  pip install python-dotenv
#   Add this to the top of any script you run locally:
#
#       from dotenv import load_dotenv
#       load_dotenv()   # reads .env into os.environ automatically
#
#   Scripts use os.environ["VARIABLE_NAME"] -- this works identically
#   locally (from .env) and in GitHub Actions (from repository secrets).
#
# =============================================================================
